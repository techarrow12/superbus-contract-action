{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superbus.dev/schemas/agent-contract.schema.json",
  "title": "Agent Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "allowed_scope"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "allowed_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_scope": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "max_files": {
      "type": "integer",
      "minimum": 0
    },
    "mode": {
      "enum": ["write_allowed", "approval_required", "inspect_only"],
      "default": "write_allowed"
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
